# ─────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=wateradmin
POSTGRES_PASSWORD=changeme_db_password
POSTGRES_DB=waterdb
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── API ──────────────────────────────────────────────────────
API_KEY=changeme_super_secret_api_key

# ── MQTT ─────────────────────────────────────────────────────
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USER=wateriot
MQTT_PASSWORD=changeme_mqtt_password

# ── SMTP Alerts ──────────────────────────────────────────────
SMTP_HOST=smtp
SMTP_PORT=25
SMTP_USER=alerts@watermonitor.local
ALERT_EMAIL=stakeholder@example.com

# ── Grafana ──────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana_password
